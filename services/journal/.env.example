# Database connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/balansi_development?sslmode=disable

# Phoenix secret key (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# OpenAI API configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS - Frontend domains (comma-separated)
FRONTEND_DOMAIN=http://localhost:5173,http://localhost:8080

# Phoenix server configuration
PHX_HOST=localhost
PORT=4000

# Enable server (set to true for Lambda)
# PHX_SERVER=true

# AWS Cognito OAuth2 configuration
# Cognito domain (Hosted UI domain)
# Example: https://your-domain.auth.us-east-2.amazoncognito.com
COGNITO_DOMAIN=

# Cognito App Client ID
# Example: 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
COGNITO_CLIENT_ID=

# Redirect URI after Cognito authentication callback
# Must match the redirect URI configured in Cognito User Pool
# Example: https://your-app.com/auth/callback
# For local development: http://localhost:4000/auth/callback
COGNITO_REDIRECT_URI=
