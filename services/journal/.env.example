# Database connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/balansi_development?sslmode=disable

# Phoenix secret key (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# OpenAI API configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS - Frontend domains (comma-separated)
FRONTEND_DOMAIN=http://localhost:5173,http://localhost:8080

# Phoenix server configuration
PHX_HOST=localhost
PORT=4000

# Enable server (set to true for Lambda)
# PHX_SERVER=true
