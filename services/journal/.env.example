# Database Configuration
DATABASE_URL=postgresql://balansi:password@localhost:5432/journal_dev

# Phoenix Configuration
SECRET_KEY_BASE=your-secret-key-base-here
# Generate with: make generate-secret

# Session Encryption (optional, falls back to SECRET_KEY_BASE if not set)
# Generate with: make generate-session-secret
SESSION_ENCRYPTION_SECRET=your-session-encryption-secret-here

# Server Configuration
PORT=4000
PHX_SERVER=true

# Cognito Configuration
COGNITO_DOMAIN=https://your-domain.auth.us-east-2.amazoncognito.com
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_REDIRECT_URI=http://localhost:4000/journal/auth/callback

# Frontend Configuration (for CORS and redirects)
FRONTEND_DOMAIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# OpenAI Configuration (optional, for AI features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Production-only variables (set in production environment)
# PHX_HOST=api.example.com
# DNS_CLUSTER_QUERY=your-dns-cluster-query
# POOL_SIZE=10
