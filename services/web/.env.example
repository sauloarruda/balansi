# Frontend Environment Variables
# Copy this file to .env and fill in your values
# 
# Note: .env files are gitignored for security

# Cognito Configuration
# Get these values from your AWS Cognito User Pool
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-east-2.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# API Configuration (optional)
# VITE_API_URL=http://localhost:3000
# VITE_JOURNAL_API_URL=http://localhost:4000

# Token Configuration (optional)
# VITE_TOKEN_EXPIRY_BUFFER_MINUTES=5
