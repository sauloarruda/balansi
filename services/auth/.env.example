# Database Configuration
# Replace with your PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/balansi_development?sslmode=disable

# Encryption Secret
# Generate a secure secret with: make generate-secret
ENCRYPTION_SECRET=your-encryption-secret-here

# Cognito Configuration (Local Development)
# Run 'make cognito-local-setup' to get these values
COGNITO_USER_POOL_ID=local_xxxxx
COGNITO_CLIENT_ID=xxxxx
COGNITO_ENDPOINT=http://localhost:9229

# Optional: Server Port (defaults to 3000)
# PORT=3000

# Frontend domain for CORS validation (accepts localhost:8080 for development)
FRONTEND_DOMAIN=localhost:8080

# API domain (e.g., api.demo.balansi.me)
# Used for cookie domain configuration and logging
API_DOMAIN=localhost:3000

# Cookie domain base (e.g., .balansi.me)
# If set, this will be used directly for the Domain attribute in cookies
# If not set, the code will extract it from FRONTEND_DOMAIN and API_DOMAIN
COOKIE_DOMAIN=localhost
